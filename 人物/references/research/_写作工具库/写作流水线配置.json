{
  "name": "写作流水线",
  "version": "1.0",
  "modules": {
    "角色索引": {"path": "角色交叉索引表.md", "load_when": "始终预加载", "tokens": "~2K"},
    "角色标签": {"path": "角色标签数据库_{类型}.json", "load_when": "选角阶段", "tokens": "~3K/文件"},
    "角色档案": {"path": "角色档案_{类型}_完整.json", "load_when": "需要完整背景时", "tokens": "~10K/文件"},
    "场景数据库": {"path": "写作场景数据库.json", "load_when": "构思阶段", "tokens": "~8K"},
    "小说大纲": {"path": "小说大纲_*.json", "load_when": "选大纲阶段", "tokens": "~3K/题材"},
    "技法库": {"path": "写作技法库.json", "load_when": "写作阶段", "tokens": "~10K"},
    "对话引擎": {"path": "对话引擎.json", "load_when": "写对话时", "tokens": "~5K"}
  },
  "pipeline_steps": [
    {"step":1,"name":"选题","load":["角色交叉索引表.md"],"action":"根据需求查交叉索引，确定题材+角色组合"},
    {"step":2,"name":"选角","load":["角色标签数据库_性格类.json","角色标签数据库_职业类.json","角色标签数据库_人物类.json"],"action":"提取角色说话方式+情绪标签+题材标签"},
    {"step":3,"name":"选大纲","load":["小说大纲_*.json"],"action":"选择或参考大纲，确定章节结构"},
    {"step":4,"name":"写场景","load":["写作场景数据库.json"],"action":"匹配开头模板+冲突触发器+高潮转折"},
    {"step":5,"name":"写正文","load":["写作技法库.json"],"action":"应用情绪描写+环境描写+节奏技法"},
    {"step":6,"name":"写对话","load":["对话引擎.json"],"action":"匹配角色说话方式+对话模板"}
  ],
  "quick_commands": [
    {"cmd":"写恐怖短篇","auto_load":["恐怖开头","病娇+哥特风+跟踪狂","恐惧情绪词库"]},
    {"cmd":"写恋爱对话","auto_load":["暧昧+告白模板","心动+甜蜜词库","深夜卧室/咖啡馆"]},
    {"cmd":"写冲突场景","auto_load":["冲突触发器","吵架模板","愤怒+崩溃词库"]},
    {"cmd":"写治愈日常","auto_load":["治愈开头","温柔对话","咖啡馆/花艺/甜品环境"]},
    {"cmd":"写悬疑推理","auto_load":["悬疑开头","秘密揭露冲突","短句紧张节奏"]},
    {"cmd":"写军旅故事","auto_load":["军旅开头","命令式对话","军人角色","压抑词库"]},
    {"cmd":"写都市现实","auto_load":["都市开头","北漂/外卖员角色","雨天/地铁/办公室"]},
    {"cmd":"写校园青春","auto_load":["校园开头","学生党/社恐/初恋","操场环境","心动词库"]},
    {"cmd":"写禁忌题材","auto_load":["禁忌开头","人妻/师生角色","老宅/车内/阳台","压抑+内疚词库"]},
    {"cmd":"写虐心文","auto_load":["虐心开头","缺爱/病娇/被渣","分手模板","悲伤+绝望词库"]}
  ],
  "token_optimization": {
    "单次短篇预估": "15-25K tokens",
    "单次章节预估": "8-15K tokens",
    "按需加载节省比": "60-80%"
  }
}